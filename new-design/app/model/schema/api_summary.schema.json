{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-reader/new-design/schema/api_summary.schema.json",
  "title": "GET /api/summary 响应",
  "description": "统计概览。counts 来自各 global 维度计数;chapters 为章号列表。",
  "type": "object",
  "required": ["chapters", "counts"],
  "properties": {
    "chapters": { "type": "array", "items": { "type": "integer" } },
    "counts": {
      "type": "object",
      "required": ["characters", "items", "locations", "events"],
      "properties": {
        "characters": { "type": "integer", "minimum": 0 },
        "items": { "type": "integer", "minimum": 0 },
        "locations": { "type": "integer", "minimum": 0 },
        "events": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
