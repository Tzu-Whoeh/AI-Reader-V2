{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-reader/new-design/schema/api_node.schema.json",
  "title": "GET /api/node/<type>/<id> 响应",
  "description": "单节点详情 + 原文出处。occurrences 由 node_anchors→find_occurrences 反查原文得到。",
  "type": "object",
  "required": ["type", "id", "occurrences"],
  "properties": {
    "type": { "$ref": "api_core.schema.json#/$defs/nodeType" },
    "id": { "type": ["integer", "string"], "description": "global_id(或事件 desc 回退)" },
    "anchors": { "type": "array", "items": { "type": "string" },
                 "description": "用于反查的锚点词集合(诊断用,可选)" },
    "occurrences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapter", "term", "sentence"],
        "properties": {
          "chapter": { "type": "integer" },
          "term": { "type": "string", "description": "命中的锚点词(前端高亮,须正则转义)" },
          "sentence": { "type": "string", "description": "含锚点的整句原文" },
          "pos": { "type": "integer", "description": "句中字符位置" }
        }
      }
    }
  }
}
