{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-reader/new-design/schema/global_characters.schema.json",
  "title": "output/global/characters.json",
  "type": "object",
  "required": ["global_characters", "relations"],
  "properties": {
    "global_characters": { "type": "array", "items": { "$ref": "core.schema.json#/$defs/globalEntity" } },
    "relations": { "type": "array", "items": { "$ref": "core.schema.json#/$defs/relation" } },
    "character_timelines": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "$ref": "core.schema.json#/$defs/timelineEntry" } }
    },
    "ambiguities": { "type": "array", "items": { "$ref": "core.schema.json#/$defs/ambiguity" } }
  }
}
