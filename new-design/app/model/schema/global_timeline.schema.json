{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-reader/new-design/schema/global_timeline.schema.json",
  "title": "output/global/timeline.json",
  "type": "object",
  "required": ["global_events"],
  "properties": {
    "global_events": { "type": "array", "items": { "$ref": "core.schema.json#/$defs/event" } },
    "character_timelines": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "$ref": "core.schema.json#/$defs/timelineEntry" } }
    },
    "sync_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "desc"],
        "properties": {
          "event_id": { "type": "integer" }, "desc": { "type": "string" },
          "global_participants": { "type": "array", "items": { "type": "integer" } },
          "chapter": { "type": "integer" }
        }
      }
    }
  }
}
