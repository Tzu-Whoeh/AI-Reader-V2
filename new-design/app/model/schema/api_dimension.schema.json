{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-reader/new-design/schema/api_dimension.schema.json",
  "title": "GET /api/dimension/<name> 响应",
  "description": "原样返回某 global 维度文件(characters/items/locations/timeline/scenes),结构即领域模型。前端 Timeline/Scenes 视图据此渲染。",
  "oneOf": [
    { "$ref": "global_characters.schema.json" },
    { "$ref": "global_items.schema.json" },
    { "$ref": "global_locations.schema.json" },
    { "$ref": "global_timeline.schema.json" },
    { "$ref": "global_scenes.schema.json" }
  ]
}
