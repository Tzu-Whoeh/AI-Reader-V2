{
  "scenes": [
    {
      "index": 1,
      "title": "抵达宪兵部",
      "type": "现实叙述",
      "location": "虹口日本宪兵司令部门口",
      "summary": "华剑雄乘车到达戒备森严的日本宪兵司令部，司机老赵感叹其受优待。",
      "start_text": "黑色的雪佛来轿车开到戒备森严的虹口日本宪兵司令部",
      "end_text": "连丁主任进出日本宪兵司令部都要停车检查的",
      "location_ref": {
        "location_id": 1,
        "matched": "虹口日本宪兵司令部"
      }
    },
    {
      "index": 2,
      "title": "回忆受宠原因",
      "type": "回忆",
      "location": "未明",
      "summary": "叙述华剑雄因被日本人精心吸收、安插在76号且有一位日本义父而深受信任的背景。",
      "start_text": "日本人的确对他们精心吸收和安插在７６号的心腹华剑雄是钟爱有加",
      "end_text": "使得华剑雄受到绝对的信任"
    },
    {
      "index": 3,
      "title": "寻找武田与心理活动",
      "type": "内心独白",
      "location": "宪兵司令部二楼办公室及花园",
      "summary": "华剑雄在办公室未找到武田，得知其在地下刑讯室后，庆幸自己昨日约酒躲过一劫并观察局势。",
      "start_text": "在宪兵司令部二楼办公室里，华剑雄没找到宪兵队长武田勇夫",
      "end_text": "而且正好可以顺便看看日本人这边有什么动静",
      "location_ref": {
        "location_id": 1,
        "matched": "宪兵司令部"
      }
    },
    {
      "index": 4,
      "title": "进入刑讯室观察",
      "type": "动作",
      "location": "地下通道及7号刑讯室",
      "summary": "华剑雄穿过花园下到地下，听到惨叫，径直走进7号房看到武田正在用烙铁拷问一名女子。",
      "start_text": "穿过宪兵司令部花园的假山，华剑雄下到宽敞的地下通道里",
      "end_text": "他正在把一把烧得暗红的三角烙铁用力地压在被平直仰卧着绑在长条刑凳上的赤裸女人高耸的胸脯上",
      "location_ref": {
        "location_id": 6,
        "matched": "地下通道"
      }
    },
    {
      "index": 5,
      "title": "告别武田离去",
      "type": "现实叙述",
      "location": "7号刑讯室及地下通道出口",
      "summary": "华剑雄与武田寒暄，武田道歉并邀请喝酒，两人大笑走出刑讯室乘车离开。",
      "start_text": "这时那女人又发出凄惨的尖叫",
      "end_text": "这时天已经快黑了，在华剑雄的招呼下，武田笨拙地钻进了他那辆黑色雪佛来",
      "location_ref": {
        "location_id": 6,
        "matched": "地下通道"
      }
    }
  ],
